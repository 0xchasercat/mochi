---
import { getCollection, render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { CATEGORY_LABELS, DOC_CATEGORIES, type DocCategory } from "../../content.config.ts";

export async function getStaticPaths() {
  const all = await getCollection("docs");
  // Build a flat ordered list once for prev/next navigation. The order is
  // category-major, then `order`-minor.
  const ordered = DOC_CATEGORIES.flatMap((cat) =>
    all
      .filter((e) => e.data.category === cat)
      .sort((a, b) => a.data.order - b.data.order)
  );
  return ordered.map((entry, idx) => {
    const prev = ordered[idx - 1];
    const next = ordered[idx + 1];
    return {
      params: { slug: entry.id },
      props: {
        entry,
        prev: prev ? { id: prev.id, title: prev.data.title } : undefined,
        next: next ? { id: next.id, title: next.data.title } : undefined,
      },
    };
  });
}

const { entry, prev, next } = Astro.props;
const { Content, headings } = await render(entry);

const githubUrl = `https://github.com/0xchasercat/mochi/blob/main/docs/content/docs/${entry.id}.${entry.filePath?.endsWith(".mdx") ? "mdx" : "md"}`;
---
<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  category={entry.data.category as DocCategory}
  currentId={entry.id}
  headings={headings}
  prev={prev}
  next={next}
  editUrl={githubUrl}
  lastUpdated={entry.data.lastUpdated}
>
  <Content />
</DocsLayout>
