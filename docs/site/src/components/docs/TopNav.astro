---
// Docs top nav — sticky, blurred. Search trigger only — the site is
// cream-only, no theme toggle (PLAN: dark mode was removed wholesale
// after the design review; raw --stealth-* color tokens still exist
// for local design accents like the landing CodeShowcase block, but
// there is no global dark/light theme).
const githubUrl = "https://github.com/0xchasercat/mochi";
const version = "0.1.2";
const currentPath = Astro.url.pathname;
const tabs = [
  { id: "docs", label: "Docs", match: ["/docs/getting-started", "/docs/concepts"], href: "/docs/getting-started/install" },
  { id: "guides", label: "Guides", match: ["/docs/guides"], href: "/docs/guides/proxy-auth" },
  { id: "api", label: "API", match: ["/docs/api"], href: "/docs/api/core" },
  { id: "reference", label: "Reference", match: ["/docs/reference"], href: "/docs/reference/invariants" },
];
const activeTab = tabs.find((t) => t.match.some((m) => currentPath.startsWith(m)))?.id;
---
<header class="d-nav">
  <a class="d-nav-brand" href="/">
    <span class="d-wordmark">mochi<span class="d-dot"></span>js</span>
    <span class="d-nav-tag">docs</span>
  </a>
  <nav class="d-nav-links">
    {tabs.map((t) => (
      <a href={t.href} class={activeTab === t.id ? "is-active" : ""}>{t.label}</a>
    ))}
  </nav>
  <div class="d-nav-actions">
    <button class="d-search" type="button" data-search-open>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      <span class="d-search-text">Search docs…</span>
      <span class="d-kbd">⌘ K</span>
    </button>
    <span class="d-version">
      <span class="d-version-dot"></span>
      v{version}
    </span>
    <a class="d-icon-btn" href={githubUrl} title="GitHub" rel="noopener">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.97.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18a10.93 10.93 0 0 1 5.76 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.68.8.56 4.56-1.52 7.84-5.83 7.84-10.91C23.5 5.65 18.35.5 12 .5z"/></svg>
    </a>
  </div>
</header>
