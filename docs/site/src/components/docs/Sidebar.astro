---
import { getCollection } from "astro:content";
import { CATEGORY_LABELS, CATEGORY_EMOJI, DOC_CATEGORIES, type DocCategory } from "../../content.config.ts";

interface Props {
  /** Active doc id (collection entry id, e.g. "getting-started/install"). */
  current?: string;
}
const { current } = Astro.props;

const all = await getCollection("docs", ({ data }) => !data.hidden);

// Group entries by category, ordered by `order`.
const grouped = new Map<DocCategory, typeof all>();
for (const cat of DOC_CATEGORIES) grouped.set(cat, []);
for (const entry of all) {
  const list = grouped.get(entry.data.category);
  if (list) list.push(entry);
}
for (const list of grouped.values()) {
  list.sort((a, b) => a.data.order - b.data.order);
}
---
<aside class="d-side" id="docs-sidebar" aria-label="Docs navigation">
  <button
    class="d-side-close"
    type="button"
    data-drawer-close
    aria-label="Close navigation drawer"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <path d="M18 6 6 18M6 6l12 12" />
    </svg>
  </button>
  {DOC_CATEGORIES.map((cat) => {
    const entries = grouped.get(cat) ?? [];
    if (entries.length === 0) return null;
    return (
      <div class="d-side-section">
        <div class="d-side-h">
          <span class="d-side-h-emoji" aria-hidden="true">{CATEGORY_EMOJI[cat]}</span>
          {CATEGORY_LABELS[cat]}
        </div>
        {entries.map((entry) => (
          <a
            class={"d-side-link" + (current === entry.id ? " is-active" : "")}
            href={`/docs/${entry.id}`}
            aria-current={current === entry.id ? "page" : undefined}
          >
            <span>{entry.data.title}</span>
          </a>
        ))}
      </div>
    );
  })}
</aside>

<script>
  // Auto-scroll the active sidebar link into view on page load. The
  // sticky-overflow sidebar otherwise renders the active link below the
  // fold for late-alphabet pages.
  const active = document.querySelector<HTMLElement>(".d-side .is-active");
  if (active) {
    // `scrollIntoView({ block: "nearest" })` keeps the sidebar from
    // jumping; only scrolls the side aside itself, not the page.
    active.scrollIntoView({ block: "nearest" });
  }
</script>
