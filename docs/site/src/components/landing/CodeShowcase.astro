---
// Code showcase — three runnable mochi snippets, rendered through Astro's
// shiki integration so syntax highlighting stays in sync with the rest
// of the site. Tabs are vanilla JS — see the inline <script> at the
// bottom.
//
// Snippets target the current public API surface (post-wreq drop):
//   • mochi.launch() / mochi.connect() — shipped
//   • Page.goto() / Page.screenshot — shipped
//   • Session.cookies.{save,load} — shipped
//   • Page.localStorage.{get,set} — shipped
//   • Page.grantAllPermissions — shipped
//   • Session.fetch — Chromium-native via CDP (no FFI)
//   • LaunchOptions.challenges.turnstile.autoClick — shipped
//   • Page.addInitScript / removeInitScript — shipped

import { Code } from "astro:components";

const launch = `import { mochi } from "@mochi.js/core";

// boot a stealth browser in three lines
const session = await mochi.launch({
  profile: "linux-chrome-stable",
  seed: "user-12345",
});

const page = await session.newPage();
await page.goto("https://target.example/checkout");

console.log("UA:", session.profile.userAgent);

await session.close();`;

const turnstile = `import { mochi } from "@mochi.js/core";

// auto-click visible-checkbox Turnstile. Other variants → onEscalation.
const session = await mochi.launch({
  profile: "mac-m4-chrome-stable",
  seed: "warm-session-001",
  challenges: {
    turnstile: {
      autoClick: true,
      onEscalation: (reason) => {
        console.warn("Turnstile escalated:", reason);
      },
    },
  },
});

const page = await session.newPage();
await page.goto("https://protected.example/login");`;

const inject = `import { mochi } from "@mochi.js/core";

const session = await mochi.launch({ profile: "windows-chrome-stable", seed: "abc" });
const page = await session.newPage();

// Run a custom inject before any page script. JIT-friendly proxy traps.
const installed = await page.addInitScript(\`
  Object.defineProperty(window, "__site_marker", { value: "mochi", configurable: false });
\`);

await page.goto("https://example.com");

// ...later: remove the inject from future navigations.
await page.removeInitScript(installed);`;
---
<section class="m-code-show">
  <div class="m-code-head">
    <div class="m-eyebrow">three-line stealth</div>
    <h2 class="m-h2">Same Playwright muscle memory.<br/>None of the crumbs.</h2>
  </div>
  <div class="m-code-frame" data-tabs>
    <div class="m-code-tabs" role="tablist" aria-label="Code examples">
      <button id="cs-tab-launch" class="m-code-tab is-active" type="button" role="tab" data-tab="launch" aria-selected="true" aria-controls="cs-panel-launch">launch.ts</button>
      <button id="cs-tab-turnstile" class="m-code-tab" type="button" role="tab" data-tab="turnstile" aria-selected="false" aria-controls="cs-panel-turnstile" tabindex="-1">turnstile.ts</button>
      <button id="cs-tab-inject" class="m-code-tab" type="button" role="tab" data-tab="inject" aria-selected="false" aria-controls="cs-panel-inject" tabindex="-1">inject.ts</button>
      <button class="m-code-copy" type="button" data-copy-tabs aria-label="Copy code">copy</button>
    </div>
    <div id="cs-panel-launch" class="m-code-body" data-panel="launch" role="tabpanel" aria-labelledby="cs-tab-launch">
      <Code code={launch} lang="ts" theme="github-dark-dimmed" />
    </div>
    <div id="cs-panel-turnstile" class="m-code-body" data-panel="turnstile" role="tabpanel" aria-labelledby="cs-tab-turnstile" hidden>
      <Code code={turnstile} lang="ts" theme="github-dark-dimmed" />
    </div>
    <div id="cs-panel-inject" class="m-code-body" data-panel="inject" role="tabpanel" aria-labelledby="cs-tab-inject" hidden>
      <Code code={inject} lang="ts" theme="github-dark-dimmed" />
    </div>
  </div>
</section>

<style>
  /* Tighten the shiki <pre> to fit inside m-code-body; it already supplies
     padding, so reset shiki's. */
  .m-code-body :global(pre.astro-code) {
    background: transparent !important;
    padding: 0;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.7;
    overflow-x: auto;
  }
</style>

<script>
  // Tab switcher + copy button. Pure DOM — no framework needed.
  const root = document.querySelector<HTMLElement>("[data-tabs]");
  if (root) {
    const tabs = root.querySelectorAll<HTMLButtonElement>("[data-tab]");
    const panels = root.querySelectorAll<HTMLElement>("[data-panel]");
    function activate(tab: HTMLButtonElement) {
      const target = tab.dataset.tab;
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle("is-active", active);
        t.setAttribute("aria-selected", active ? "true" : "false");
        t.setAttribute("tabindex", active ? "0" : "-1");
      });
      panels.forEach((p) => {
        p.hidden = p.dataset.panel !== target;
      });
    }
    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => activate(tab));
      tab.addEventListener("keydown", (e) => {
        // Arrow-key navigation per WAI-ARIA Authoring Practices for tabs.
        if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
          e.preventDefault();
          const dir = e.key === "ArrowRight" ? 1 : -1;
          const next = tabs[(i + dir + tabs.length) % tabs.length];
          activate(next);
          next.focus();
        }
      });
    });

    const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy-tabs]");
    copyBtn?.addEventListener("click", async () => {
      const visiblePanel = Array.from(panels).find((p) => !p.hidden);
      const text = visiblePanel?.querySelector("pre")?.textContent ?? "";
      try {
        await navigator.clipboard?.writeText(text);
        if (copyBtn) {
          copyBtn.textContent = "copied ✓";
          setTimeout(() => {
            copyBtn.textContent = "copy";
          }, 1200);
        }
      } catch (_err) {
        if (copyBtn) copyBtn.textContent = "—";
      }
    });
  }
</script>
