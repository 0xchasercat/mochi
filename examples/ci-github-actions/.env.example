# Optional: outbound proxy for runs that need a non-runner egress IP.
# The workflow forwards `secrets.PROXY_URL` into this name automatically.
PROXY_URL=

# GitHub Actions sets this for free; locally you can pin it for stable seeds.
GITHUB_RUN_ID=local-dev

# Comma- / space-separated list of extra Chromium args. Auto-set to
# --no-sandbox under root + Linux; explicit-set in the workflow for clarity.
MOCHI_EXTRA_ARGS=--no-sandbox
