{
  "name": "@mochi.js/cli",
  "version": "0.2.0",
  "description": "The mochi command — browsers install, capture, harness, work. The CLI surface for mochi.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "mochi": "./src/bin.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.1"
  },
  "homepage": "https://github.com/0xchasercat/mochi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xchasercat/mochi.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "mochi",
    "cli"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src/",
    "lint": "biome check src/",
    "build": "echo 'no build step yet'"
  },
  "dependencies": {
    "@mochi.js/consistency": "workspace:*",
    "@mochi.js/core": "workspace:*",
    "@mochi.js/harness": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
