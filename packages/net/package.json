{
  "name": "@mochi.js/net",
  "version": "0.0.1",
  "description": "TS facade for @mochi.js/net-rs — out-of-band HTTP with profile-matching JA3/JA4 via Rust+wreq + Bun:FFI.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.1"
  },
  "homepage": "https://github.com/0xchasercat/mochi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xchasercat/mochi.git",
    "directory": "packages/net"
  },
  "keywords": [
    "mochi",
    "tls",
    "ja3",
    "ja4",
    "http2",
    "impersonation",
    "wreq"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src/",
    "lint": "biome check src/",
    "build": "echo 'no build step yet'"
  },
  "dependencies": {
    "@mochi.js/net-rs": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
