{
  "name": "@mochi.js/profiles",
  "version": "0.2.1",
  "description": "Profile data fixtures for mochi — captured baselines (profile.json + Probe Manifest + audio bytes + canvas hashes) per device class.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "data",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.1"
  },
  "homepage": "https://github.com/0xchasercat/mochi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xchasercat/mochi.git",
    "directory": "packages/profiles"
  },
  "keywords": [
    "mochi",
    "fingerprint",
    "profiles"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src/",
    "lint": "biome check src/",
    "build": "echo 'no build step yet'"
  },
  "dependencies": {
    "@mochi.js/consistency": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
